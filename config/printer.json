{
  "version": "1.0",
  "printer_model": "STM32F407_3DPrinter",
  "communication": {
    "serial": {
      "port": "COM7",
      "baud_rate": 57600,
      "data_bits": 8,
      "parity": "None",
      "stop_bits": 1,
      "timeout_ms": 1000,
      "flow_control": false
    },
    "status_report_interval_ms": 1000
  },
  "gcode_settings": {
    "motion_batch_size": 4
  },
  "temperature_presets": [
    {
      "name": "PLA",
      "hotend_temp": 200.0,
      "bed_temp": 60.0,
      "chamber_temp": null,
      "fan_speed": 255
    },
    {
      "name": "ABS",
      "hotend_temp": 240.0,
      "bed_temp": 100.0,
      "chamber_temp": 50.0,
      "fan_speed": 0
    },
    {
      "name": "PETG",
      "hotend_temp": 230.0,
      "bed_temp": 70.0,
      "chamber_temp": null,
      "fan_speed": 128
    }
  ],
  "temperature_safety": {
    "safety_check_interval_ms": 1000,
    "temp_change_threshold": 1.0,
    "heaters": {
      "hotend": {
        "sensor_fault": {
          "max_temp": 300.0,
          "min_temp": -50.0
        },
        "deviation_thresholds": {
          "warning": 10.0,
          "critical": 15.0,
          "emergency": 20.0
        },
        "heating_delay_secs": 60,
        "actions": {
          "low_temp": {
            "warning": "warn",
            "critical": "pause_print",
            "emergency": "emergency_stop"
          },
          "high_temp": {
            "warning": "warn",
            "critical": "turn_off",
            "emergency": "emergency_stop"
          }
        }
      },
      "bed": {
        "sensor_fault": {
          "max_temp": 200.0,
          "min_temp": -50.0
        },
        "deviation_thresholds": {
          "warning": 10.0,
          "critical": 15.0,
          "emergency": 20.0
        },
        "heating_delay_secs": 120,
        "actions": {
          "low_temp": {
            "warning": "warn",
            "critical": "warn",
            "emergency": "turn_off"
          },
          "high_temp": {
            "warning": "warn",
            "critical": "turn_off",
            "emergency": "emergency_stop"
          }
        }
      }
    }
  }
}
