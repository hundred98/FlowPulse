{
  "version": "1.0",
  "motor": [
    {
      "axis": "X",
      "step_pin": "PE3",
      "dir_pin": "PE2",
      "enable_pin": "!PE4",
      "steps_per_mm": 80,
      "max_speed_mm_per_s": 400,
      "max_accel": 20000,
      "position_min": 0,
      "position_max": 300,
      "driver": {
        "uart_pin": "",
        "microsteps": 16,
        "current_ma": 800,
        "hold_current_ma": 500,
        "stealthchop_threshold": 999999
      }
    },
    {
      "axis": "Y",
      "step_pin": "PE0",
      "dir_pin": "PB9",
      "enable_pin": "!PE1",
      "steps_per_mm": 80,
      "max_speed_mm_per_s": 400,
      "max_accel": 20000,
      "position_min": 0,
      "position_max": 300,
      "driver": {
        "uart_pin": "",
        "microsteps": 16,
        "current_ma": 800,
        "hold_current_ma": 500,
        "stealthchop_threshold": 999999
      }
    },
    {
      "axis": "Z",
      "step_pin": "PB5",
      "dir_pin": "PB4",
      "enable_pin": "!PB8",
      "steps_per_mm": 400,
      "max_speed_mm_per_s": 20,
      "max_accel": 500,
      "position_min": 0,
      "position_max": 200,
      "driver": {
        "uart_pin": "",
        "microsteps": 16,
        "current_ma": 800,
        "hold_current_ma": 500,
        "stealthchop_threshold": 999999
      }
    },
    {
      "axis": "E0",
      "step_pin": "PD6",
      "dir_pin": "!PD3",
      "enable_pin": "!PB3",
      "steps_per_mm": 80,
      "max_speed_mm_per_s": 50,
      "max_accel": 5000,
      "position_min": 0,
      "position_max": 0,
      "driver": {
        "uart_pin": "",
        "microsteps": 16,
        "current_ma": 600,
        "hold_current_ma": 300,
        "stealthchop_threshold": 999999
      },
      "extruder": {
        "nozzle_diameter_mm": 0.4,
        "filament_diameter_mm": 1.75,
        "max_flow_rate": 25
      }
    }
  ],
  "temperature": {
    "hotbed": {
      "sensor_type": "NTC100K",
      "adc_pin": "PC0",
      "beta": 3950,
      "ntc_resistance_25c": 100000,
      "pullup_resistor": 4700,
      "min_temp": 0,
      "max_temp": 130,
      "kp": 325.10,
      "ki": 63.35,
      "kd": 417.10,
      "pid_interval_ms": 100
    },
    "hotend": {
      "sensor_type": "NTC100K",
      "adc_pin": "PC1",
      "beta": 3950,
      "ntc_resistance_25c": 100000,
      "pullup_resistor": 4700,
      "min_temp": 0,
      "max_temp": 250,
      "kp": 14.669,
      "ki": 0.572,
      "kd": 94.068,
      "pid_interval_ms": 100
    }
  },
  "heater": {
    "hotbed": {
      "pin": "PA0",
      "active_high": true,
      "pwm_freq_hz": 10,
      "max_power": 100,
      "safety": {
        "max_temp_deviation": 5,
        "min_temp_deviation": -10,
        "heating_timeout_ms": 300000,
        "sensor_fault_threshold": 50
      }
    },
    "hotend": {
      "pin": "PE5",
      "active_high": true,
      "pwm_freq_hz": 10,
      "max_power": 100,
      "safety": {
        "max_temp_deviation": 5,
        "min_temp_deviation": -10,
        "heating_timeout_ms": 300000,
        "sensor_fault_threshold": 50
      }
    }
  },
  "gpio": {
    "output": [
      {
        "name": "box_fan",
        "pin": "PA5",
        "type": "pwm",
        "active_high": true,
        "pwm_freq_hz": 100,
        "default_value": 0.0,
        "shutdown_value": 0.0,
        "max_value": 1.0
      },
      {
        "name": "hotend_fan",
        "pin": "PA6",
        "type": "pwm",
        "active_high": true,
        "pwm_freq_hz": 100,
        "default_value": 0.0,
        "shutdown_value": 0.0,
        "max_value": 1.0
      },
      {
        "name": "chamber_led",
        "pin": "PA8",
        "type": "digital",
        "active_high": true,
        "default_value": 0
      }
    ],
    "input": [
      {
        "name": "filament_sensor",
        "pin": "PC5",
        "type": "digital",
        "pull": "up",
        "active_high": true,
        "debounce_ms": 50,
        "report": {
          "mode": "on_change",
          "trigger": "rising",
          "event": {
            "action": "filament_runout"
          }
        }
      },
      {
        "name": "door_sensor",
        "pin": "PA7",
        "type": "digital",
        "pull": "up",
        "active_high": true,
        "report": {
          "mode": "interval",
          "interval_ms": 10000
        }
      },
      {
        "name": "power_monitor",
        "pin": "PA2",
        "type": "analog",
        "pull": "none",
        "adc_resolution": 12,
        "calibration": {
          "offset": 0.0,
          "scale": 1.0,
          "min_value": 0.0,
          "max_value": 1.0
        },
        "report": {
          "mode": "on_change",
          "threshold": 0.2,
          "event": {
            "action": "power_loss"
          }
        }
      }
    ]
  },
  "fan": [
    {
      "index": 0,
      "name": "hotend_fan",
      "description": "Hotend cooling fan"
    },
    {
      "index": 1,
      "name": "box_fan",
      "description": "Box cooling fan"
    }
  ]
}
